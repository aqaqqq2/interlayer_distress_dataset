class Mlp(nn.Module):
    def __init__(self, in_features, hidden_features=None, out_features=None, act_layer=nn.GELU, drop=0.):
        super().__init__()
        out_features = out_features or in_features
        hidden_features = hidden_features or in_features
        self.fc1 = nn.Linear(in_features, hidden_features)
        self.act = act_layer()
        self.fc2 = nn.Linear(hidden_features, out_features)
        self.drop = nn.Dropout(drop)

    def forward(self, x):
        x = self.fc1(x)
        x = self.act(x)
        x = self.drop(x)
        x = self.fc2(x)
        x = self.drop(x)
        return x


class SEMlp(nn.Module):
    """Conv-based MLP with Squeeze-and-Excitation on cls_token.

    Architecture: pointwise conv -> depthwise conv -> pointwise conv,
    followed by SE module applied to cls_token generated from conv features.
    """

    def __init__(self, in_features, hidden_features=None, out_features=None, act_layer=nn.GELU, drop=0.,
                 kernel_size=3, with_bn=True):
        super().__init__()
        out_features = out_features or in_features
        hidden_features = hidden_features or in_features
        self.conv1 = nn.Conv2d(in_features, hidden_features, kernel_size=1, stride=1, padding=0)
        self.conv2 = nn.Conv2d(
            hidden_features, hidden_features, kernel_size=kernel_size, stride=1,
            padding=(kernel_size - 1) // 2, groups=hidden_features)
        self.conv3 = nn.Conv2d(hidden_features, out_features, kernel_size=1, stride=1, padding=0)
        self.act = act_layer()

        self.bn1 = nn.BatchNorm2d(hidden_features)
        self.bn2 = nn.BatchNorm2d(hidden_features)
        self.bn3 = nn.BatchNorm2d(out_features)

        self.squeeze = nn.AdaptiveAvgPool2d((1, 1))
        self.compress = nn.Linear(in_features, in_features // 4)
        self.excitation = nn.Linear(in_features // 4, in_features)

    def forward(self, x):
        B, N, C = x.size()
        _, tokens = torch.split(x, [1, N - 1], dim=1)
        x = tokens.reshape(B, int(math.sqrt(N - 1)), int(math.sqrt(N - 1)), C).permute(0, 3, 1, 2)

        x = self.conv1(x)
        x = self.bn1(x)
        x = self.act(x)

        x = self.conv2(x)
        x = self.bn2(x)
        x = self.act(x)

        x = self.conv3(x)
        x = self.bn3(x)

        # Generate cls_token from conv features via global pooling, then apply SE
        cls_token = self.squeeze(x).flatten(1).reshape(B, 1, C)
        weight = self.excitation(self.act(self.compress(cls_token.squeeze(1))))
        cls_token = cls_token * weight.reshape(B, 1, C)

        tokens = x.flatten(2).permute(0, 2, 1)
        out = torch.cat((cls_token, tokens), dim=1)
        return out


class MStripAttention(nn.Module):
    """Multi-head strip-shaped local attention with dilation."""

    def __init__(self, head_dim, qk_scale=None, attn_drop=0, kernel_size=3, dilation=1, strip_type='horizontal'):
        super().__init__()
        self.head_dim = head_dim
        self.scale = qk_scale or head_dim ** -0.5
        self.kernel_size = kernel_size
        self.dilation = dilation
        self.strip_type = strip_type

        if strip_type == 'horizontal':
            self.kernel = (1, kernel_size)
        else:
            self.kernel = (kernel_size, 1)

        padding = (dilation * (self.kernel[0] - 1) // 2, dilation * (self.kernel[1] - 1) // 2)
        self.unfold = nn.Unfold(self.kernel, dilation, padding, 1)
        self.window_size = self.kernel[0] * self.kernel[1]
        self.attn_drop = nn.Dropout(attn_drop)

    def forward(self, q, k, v):
        B, d, H, W = q.shape
        q = q.reshape(B, d // self.head_dim, self.head_dim, 1, H * W).permute(0, 1, 4, 3, 2)
        k = self.unfold(k).reshape(B, d // self.head_dim, self.head_dim, self.window_size, H * W).permute(0, 1, 4, 2, 3)
        attn = (q @ k) * self.scale
        attn = attn.softmax(dim=-1)
        attn = self.attn_drop(attn)
        v = self.unfold(v).reshape(B, d // self.head_dim, self.head_dim, self.window_size, H * W).permute(0, 1, 4, 3, 2)
        x = (attn @ v).transpose(1, 2).reshape(B, H, W, d)
        return x


class MultiMStripAttention(nn.Module):
    """Multi-dilation strip-shaped local attention.

    Splits heads into groups, each with a different dilation rate.
    """

    def __init__(self, dim, num_heads=8, qkv_bias=False, qk_scale=None,
                 attn_drop=0., proj_drop=0., kernel_size=3, dilation=None, strip_type='vertical'):
        super().__init__()
        self.dim = dim
        self.num_heads = num_heads
        self.dilation = dilation or [1, 2, 3]
        self.kernel_size = kernel_size
        self.num_dilation = len(self.dilation)
        self.strip_type = strip_type

        head_dim = dim // num_heads
        self.scale = qk_scale or head_dim ** -0.5

        assert num_heads % self.num_dilation == 0, \
            f"num_heads ({num_heads}) must be a multiple of num_dilation ({self.num_dilation})"

        self.qkv = nn.Conv2d(dim, dim * 3, 1, bias=qkv_bias)
        self.dilate_attention = nn.ModuleList([
            MStripAttention(head_dim, qk_scale, attn_drop, kernel_size, self.dilation[i], strip_type)
            for i in range(self.num_dilation)
        ])
        self.proj = nn.Linear(dim, dim)
        self.proj_drop = nn.Dropout(proj_drop)

    def forward(self, x):
        B, H, W, C = x.shape
        x = x.permute(0, 3, 1, 2)

        qkv = self.qkv(x).reshape(B, 3, self.num_dilation, C // self.num_dilation, H, W).permute(2, 1, 0, 3, 4, 5)
        x = x.reshape(B, self.num_dilation, C // self.num_dilation, H, W).permute(1, 0, 3, 4, 2)

        for i in range(self.num_dilation):
            x[i] = self.dilate_attention[i](qkv[i][0], qkv[i][1], qkv[i][2]).detach().clone()

        x = x.permute(1, 2, 3, 0, 4).reshape(B, H, W, C)
        x = self.proj(x)
        x = self.proj_drop(x)
        return x


class MStripBlock(nn.Module):
    """Transformer block with multi-dilation strip-shaped local attention."""

    def __init__(self, dim, num_heads, mlp_ratio=4., qkv_bias=False, qk_scale=None, drop=0., attn_drop=0.,
                 drop_path=0., act_layer=nn.GELU, norm_layer=nn.LayerNorm, kernel_size=3, dilation=None,
                 cpe_per_block=False, strip_type='horizontal'):
        super().__init__()
        self.cpe_per_block = cpe_per_block
        if self.cpe_per_block:
            self.pos_embed = nn.Conv2d(dim, dim, 3, padding=1, groups=dim)

        self.norm1 = norm_layer(dim)
        self.attn = MultiMStripAttention(
            dim, num_heads=num_heads, qkv_bias=qkv_bias, qk_scale=qk_scale,
            attn_drop=attn_drop, kernel_size=kernel_size, dilation=dilation, strip_type=strip_type)
        self.drop_path = DropPath(drop_path) if drop_path > 0. else nn.Identity()

        self.norm2 = norm_layer(dim)
        mlp_hidden_dim = int(dim * mlp_ratio)
        self.mlp = Mlp(in_features=dim, hidden_features=mlp_hidden_dim, act_layer=act_layer, drop=drop)

    def forward(self, x):
        if self.cpe_per_block:
            x = x + self.pos_embed(x)
        x = x.permute(0, 2, 3, 1)
        x = x + self.drop_path(self.attn(self.norm1(x)))
        x = x + self.drop_path(self.mlp(self.norm2(x)))
        x = x.permute(0, 3, 1, 2)
        return x


class PatchEmbed(nn.Module):
    """Image to Patch Embedding."""

    def __init__(self, img_size=224, in_chans=3, hidden_dim=16, patch_size=4, embed_dim=96, patch_way=None):
        super().__init__()
        img_size = to_2tuple(img_size)
        patch_size = to_2tuple(patch_size)
        self.img_size = img_size
        self.num_patches = (img_size[0] // patch_size[0]) * (img_size[1] // patch_size[1])

        assert patch_way in ['overlaping', 'nonoverlaping', 'pointconv'], \
            f"Unknown patch_way: {patch_way}"

        if patch_way == 'nonoverlaping':
            self.proj = nn.Conv2d(in_chans, embed_dim, kernel_size=patch_size, stride=patch_size)
        elif patch_way == 'overlaping':
            self.proj = nn.Sequential(
                nn.Conv2d(in_chans, hidden_dim, kernel_size=3, stride=1, padding=1, bias=False),
                nn.BatchNorm2d(hidden_dim),
                nn.GELU(),
                nn.Conv2d(hidden_dim, int(hidden_dim * 2), kernel_size=3, stride=2, padding=1, bias=False),
                nn.BatchNorm2d(int(hidden_dim * 2)),
                nn.GELU(),
                nn.Conv2d(int(hidden_dim * 2), int(hidden_dim * 4), kernel_size=3, stride=1, padding=1, bias=False),
                nn.BatchNorm2d(int(hidden_dim * 4)),
                nn.GELU(),
                nn.Conv2d(int(hidden_dim * 4), embed_dim, kernel_size=3, stride=2, padding=1, bias=False),
            )
        else:
            self.proj = nn.Sequential(
                nn.Conv2d(in_chans, hidden_dim, kernel_size=3, stride=2, padding=1, bias=False),
                nn.BatchNorm2d(hidden_dim),
                nn.GELU(),
                nn.Conv2d(hidden_dim, int(hidden_dim * 2), kernel_size=1, stride=1, padding=0, bias=False),
                nn.BatchNorm2d(int(hidden_dim * 2)),
                nn.GELU(),
                nn.Conv2d(int(hidden_dim * 2), int(hidden_dim * 4), kernel_size=3, stride=2, padding=1, bias=False),
                nn.BatchNorm2d(int(hidden_dim * 4)),
                nn.GELU(),
                nn.Conv2d(int(hidden_dim * 4), embed_dim, kernel_size=1, stride=1, padding=0, bias=False),
            )

    def forward(self, x):
        B, C, H, W = x.shape
        assert H == self.img_size[0] and W == self.img_size[1], \
            f"Input size ({H}*{W}) does not match model ({self.img_size[0]}*{self.img_size[1]})"
        x = self.proj(x)
        return x


class PatchMerging(nn.Module):
    """Patch Merging Layer with downsampling."""

    def __init__(self, in_channels, out_channels, merging_way, cpe_per_satge, norm_layer=nn.BatchNorm2d):
        super().__init__()
        assert merging_way in ['conv3_2', 'conv2_2', 'avgpool3_2', 'avgpool2_2'], \
            f"Unknown merging_way: {merging_way}"

        self.cpe_per_satge = cpe_per_satge
        if merging_way == 'conv3_2':
            self.proj = nn.Sequential(
                nn.Conv2d(in_channels, out_channels, kernel_size=3, stride=2, padding=1),
                norm_layer(out_channels),
            )
        elif merging_way == 'conv2_2':
            self.proj = nn.Sequential(
                nn.Conv2d(in_channels, out_channels, kernel_size=2, stride=2, padding=0),
                norm_layer(out_channels),
            )
        elif merging_way == 'avgpool3_2':
            self.proj = nn.Sequential(
                nn.AvgPool2d(in_channels, out_channels, kernel_size=3, stride=2, padding=1),
                norm_layer(out_channels),
            )
        else:
            self.proj = nn.Sequential(
                nn.AvgPool2d(in_channels, out_channels, kernel_size=2, stride=2, padding=0),
                norm_layer(out_channels),
            )

        if self.cpe_per_satge:
            self.pos_embed = nn.Conv2d(out_channels, out_channels, 3, padding=1, groups=out_channels)

    def forward(self, x):
        x = self.proj(x)
        if self.cpe_per_satge:
            x = x + self.pos_embed(x)
        return x


class MStripStage(nn.Module):
    """Stage composed of MStripBlocks with optional downsampling."""

    def __init__(self, dim, depth, num_heads, kernel_size, dilation,
                 mlp_ratio=4., qkv_bias=True, qk_scale=None, drop=0.,
                 attn_drop=0., drop_path=0., act_layer=nn.GELU,
                 norm_layer=nn.LayerNorm, cpe_per_satge=False, cpe_per_block=False,
                 downsample=True, merging_way=None, stage=0, strip_type='horizontal'):
        super().__init__()
        self.blocks = nn.ModuleList([
            MStripBlock(
                dim=dim, num_heads=num_heads, kernel_size=kernel_size, dilation=dilation,
                mlp_ratio=mlp_ratio, qkv_bias=qkv_bias, qk_scale=qk_scale,
                drop=drop, attn_drop=attn_drop,
                drop_path=drop_path[i] if isinstance(drop_path, list) else drop_path,
                norm_layer=norm_layer, act_layer=act_layer, cpe_per_block=cpe_per_block,
                strip_type=strip_type)
            for i in range(depth)
        ])
        self.downsample = PatchMerging(dim, int(dim * 2), merging_way, cpe_per_satge) if downsample else nn.Identity()

    def forward(self, x):
        for blk in self.blocks:
            x = blk(x)
        x = self.downsample(x)
        return x


class Attention(nn.Module):
    """Standard multi-head self-attention."""

    def __init__(self, dim, num_heads=8, qkv_bias=False, attn_drop=0., proj_drop=0.):
        super().__init__()
        self.num_heads = num_heads
        head_dim = dim // num_heads
        self.scale = head_dim ** -0.5

        self.qkv = nn.Linear(dim, dim * 3, bias=qkv_bias)
        self.attn_drop = nn.Dropout(attn_drop)
        self.proj = nn.Linear(dim, dim)
        self.proj_drop = nn.Dropout(proj_drop)

    def forward(self, x):
        B, N, C = x.shape
        qkv = self.qkv(x).reshape(B, N, 3, self.num_heads, C // self.num_heads).permute(2, 0, 3, 1, 4)
        q, k, v = qkv[0], qkv[1], qkv[2]

        attn = (q @ k.transpose(-2, -1)) * self.scale
        attn = attn.softmax(dim=-1)
        attn = self.attn_drop(attn)

        x = (attn @ v).transpose(1, 2).reshape(B, N, C)
        x = self.proj(x)
        x = self.proj_drop(x)
        return x


class DWConv(nn.Module):
    """Depthwise convolution module."""

    def __init__(self, dim=256):
        super(DWConv, self).__init__()
        self.dwconv = nn.Conv2d(dim, dim, 7, 1, 3, bias=True, groups=dim)

    def forward(self, x):
        x = self.dwconv(x)
        x = x.flatten(2).transpose(1, 2)
        return x


class _ScaleModule(nn.Module):
    """Learnable per-element scaling."""

    def __init__(self, dims, init_scale=1.0, init_bias=0):
        super(_ScaleModule, self).__init__()
        self.dims = dims
        self.weight = nn.Parameter(torch.ones(*dims) * init_scale)
        self.bias = None

    def forward(self, x):
        return torch.mul(self.weight, x)


class AWR(nn.Module):
    """Adaptive Wavelet Reconstruction module.

    Applies wavelet decomposition, processes subbands, then reconstructs
    with adaptive per-channel subband scaling.
    """

    def __init__(self, in_channels, out_channels, kernel_size, stride=1, bias=True, wt_type='haar'):
        super(AWR, self).__init__()
        assert in_channels == out_channels

        self.in_channels = in_channels
        self.stride = stride

        self.wt_filter, self.iwt_filter = create_wavelet_filter(wt_type, in_channels, in_channels, torch.float)
        self.wt_filter = nn.Parameter(self.wt_filter, requires_grad=False)
        self.iwt_filter = nn.Parameter(self.iwt_filter, requires_grad=False)

        self.wt_function = partial(wavelet_transform, filters=self.wt_filter)
        self.iwt_function = partial(inverse_wavelet_transform, filters=self.iwt_filter)

        self.base_conv = nn.Conv2d(
            in_channels, in_channels, kernel_size, padding='same',
            stride=1, dilation=1, groups=in_channels, bias=bias)
        self.base_scale = _ScaleModule([1, in_channels, 1, 1])

        self.wavelet_conv = nn.Conv2d(
            in_channels * 4, in_channels * 4, kernel_size, padding='same',
            stride=1, dilation=1, groups=in_channels * 4, bias=False)
        self.wavelet_scale = _ScaleModule([1, in_channels * 4, 1, 1], init_scale=0.1)

        self.subband_scale = nn.Parameter(torch.ones(1, in_channels, 4, 1, 1))
        with torch.no_grad():
            self.subband_scale[:, :, 2, :, :] = 0.1  # HL
            self.subband_scale[:, :, 3, :, :] = 0.1  # HH

        if self.stride > 1:
            self.stride_filter = nn.Parameter(torch.ones(in_channels, 1, 1, 1), requires_grad=False)
            self.do_stride = lambda x_in: F.conv2d(x_in, self.stride_filter, bias=None, stride=self.stride,
                                                   groups=in_channels)
        else:
            self.do_stride = None

    def forward(self, x):
        curr_shape = x.shape
        if (curr_shape[2] % 2 > 0) or (curr_shape[3] % 2 > 0):
            curr_pads = (0, curr_shape[3] % 2, 0, curr_shape[2] % 2)
            x = F.pad(x, curr_pads)

        wt_x = self.wt_function(x)
        shape_wt_x = wt_x.shape
        wt_x_reshaped = wt_x.reshape(shape_wt_x[0], shape_wt_x[1] * 4, shape_wt_x[3], shape_wt_x[4])
        wt_x_processed = self.wavelet_scale(self.wavelet_conv(wt_x_reshaped))
        wt_x_processed = wt_x_processed.reshape(shape_wt_x)

        wt_x_processed = wt_x_processed * self.subband_scale

        x_ll = wt_x_processed[:, :, 0, :, :]
        x_h = wt_x_processed[:, :, 1:4, :, :]

        x_tag = self.iwt_function(torch.cat([x_ll.unsqueeze(2), x_h], dim=2))
        x_tag = x_tag[:, :, :curr_shape[2], :curr_shape[3]]

        x_out = self.base_scale(self.base_conv(x))
        x_out = x_out + x_tag

        if self.do_stride is not None:
            x_out = self.do_stride(x_out)
        x_out = x_out.flatten(2).transpose(1, 2)
        return x_out


class Conv(nn.Module):
    """Standard convolution block: Conv2d + BN + activation."""

    def __init__(self, c1, c2, k=1, s=1, g=1, act=True):
        super().__init__()
        self.conv = nn.Conv2d(c1, c2, k, stride=s, padding=k // 2, groups=g, bias=False)
        self.bn = nn.BatchNorm2d(c2)
        self.act = nn.SiLU() if act else nn.Identity()

    def forward(self, x):
        return self.act(self.bn(self.conv(x)))


class SPSA(nn.Module):
    """Spatial Pyramid Split Attention with wavelet-based processing."""

    def __init__(self, dim, num_heads=8, qkv_bias=False, qk_scale=None, attn_drop=0., proj_drop=0.,
                 split_num=1 / 2, attn_ratio=0.5, norm_layer=nn.LayerNorm):
        super().__init__()
        self.num_heads = num_heads
        self.head_dim = dim // num_heads
        self.dim = dim
        self.key_dim = int(self.head_dim * attn_ratio)
        self.scale = self.key_dim ** -0.5
        self.s = int(split_num * dim)

        self.qkv = Conv(dim, dim * 3, 1)
        self.proj = Conv(dim, dim, 1)

        self.cv1 = Conv(dim, dim, 1, 1)
        self.cv2 = norm_layer(dim)

        self.cva = AWR(self.s, self.s, 3, 1)
        self.cvb = AWR(self.s, self.s, 7, 1)

        self.norma = norm_layer(self.s)
        self.normb = norm_layer(self.s)

        self.attention_a = Attention(self.s, num_heads, qkv_bias, attn_drop, proj_drop)
        self.attention_b = Attention(self.s, num_heads, qkv_bias, attn_drop, proj_drop)

    def process_part(self, x, cls_token, conv_layer, attn_layer, norm_layer):
        x = conv_layer(x)
        x = torch.cat((x, cls_token), dim=1)
        x = attn_layer(x.view(x.size(0), -1, self.s))
        return x + norm_layer(x)

    def forward(self, x):
        B, N, C = x.size()
        cls_token, tokens = torch.split(x, [1, N - 1], dim=1)
        x = tokens.reshape(B, int(math.sqrt(N - 1)), int(math.sqrt(N - 1)), C).permute(0, 3, 1, 2)

        a, b = self.cv1(x).split(self.s, dim=1)
        cls_a, cls_b = torch.split(cls_token, C // 2, dim=2)

        a = self.process_part(a, cls_a, self.cva, self.attention_a, self.norma)
        b = self.process_part(b, cls_b, self.cvb, self.attention_b, self.normb)

        out = self.cv2(torch.cat((a, b), dim=2))
        return out


class SpsaBlock(nn.Module):
    """Transformer block with SPSA attention and SEMlp."""

    def __init__(self, dim, num_heads, mlp_ratio=4., qkv_bias=False, qk_scale=None, drop=0.,
                 attn_drop=0., drop_path=0., act_layer=nn.GELU, norm_layer=nn.LayerNorm,
                 cpe_per_block=False):
        super().__init__()
        self.cpe_per_block = cpe_per_block
        if self.cpe_per_block:
            self.pos_embed = nn.Conv2d(dim, dim, 3, padding=1, groups=dim)

        self.norm1 = norm_layer(dim)
        self.attn = SPSA(dim, num_heads=num_heads, qkv_bias=qkv_bias, qk_scale=qk_scale, attn_drop=attn_drop)
        self.drop_path = DropPath(drop_path) if drop_path > 0. else nn.Identity()

        self.norm2 = norm_layer(dim)
        mlp_hidden_dim = int(dim * mlp_ratio)
        self.mlp = SEMlp(in_features=dim, hidden_features=mlp_hidden_dim, kernel_size=3,
                         act_layer=act_layer, drop=drop)

    def forward(self, x):
        if self.cpe_per_block:
            x = x + self.pos_embed(x)
        x = x + self.drop_path(self.attn(self.norm1(x)))
        x = x + self.drop_path(self.mlp(self.norm2(x)))
        return x


class SpsaStage(nn.Module):
    """Stage composed of SpsaBlocks with optional downsampling."""

    def __init__(self, dim, depth, num_heads, mlp_ratio=4., qkv_bias=True, qk_scale=None,
                 drop=0., attn_drop=0., drop_path=0.1, act_layer=nn.GELU, norm_layer=nn.LayerNorm,
                 cpe_per_satge=False, cpe_per_block=False, downsample=True, merging_way=None):
        super().__init__()
        self.blocks = nn.ModuleList([
            SpsaBlock(
                dim=dim, num_heads=num_heads, mlp_ratio=mlp_ratio, qkv_bias=qkv_bias,
                qk_scale=qk_scale, drop=drop, attn_drop=attn_drop,
                drop_path=drop_path[i] if isinstance(drop_path, list) else drop_path,
                norm_layer=norm_layer, act_layer=act_layer, cpe_per_block=cpe_per_block)
            for i in range(depth)
        ])
        self.downsample = PatchMerging(dim, int(dim * 2), merging_way, cpe_per_satge) if downsample else nn.Identity()

    def forward(self, x):
        for blk in self.blocks:
            x = blk(x)
        x = self.downsample(x)
        return x


class WMTransformer(nn.Module):
    """WM-Transformer: Wavelet-based Multi-scale Transformer backbone."""

    def __init__(self, img_size=224, patch_size=4, in_chans=3, num_classes=1000,
                 embed_dim=None, depths=None, num_heads=None,
                 kernel_size=3, dilation=None, mlp_ratio=4.,
                 qkv_bias=True, qk_scale=None, drop=0., attn_drop=0., drop_path=0.1,
                 norm_layer=partial(nn.LayerNorm, eps=1e-6), merging_way='conv3_2',
                 patch_way='overlaping', dilate_attention=None,
                 downsamples=None, cpe_per_satge=False):
        super().__init__()
        embed_dim = embed_dim or [96, 192, 512]
        depths = depths or [2, 2, 6]
        num_heads = num_heads or [3, 6, 12]
        dilation = dilation or [1, 2, 3]
        dilate_attention = dilate_attention or [True, True, False]
        downsamples = downsamples or [True, True, False]

        self.num_classes = num_classes
        self.num_layers = len(depths)
        self.embed_dim = embed_dim
        self.num_features = embed_dim[-1]
        self.mlp_ratio = mlp_ratio
        norm_layer = norm_layer or partial(nn.LayerNorm, eps=1e-6)

        self.proj = nn.Conv2d(embed_dim[-2] * 2, embed_dim[-1], kernel_size=1, stride=1)

        self.patch_embed = PatchEmbed(
            img_size=img_size, patch_size=patch_size,
            in_chans=in_chans, embed_dim=embed_dim[0], patch_way=patch_way)

        dpr = [x.item() for x in torch.linspace(0, drop_path, sum(depths))]
        self.stages = nn.ModuleList()

        for i_layer in range(self.num_layers):
            cpe_block = dilate_attention[i_layer]
            if dilate_attention[i_layer]:
                stage = MStripStage(
                    dim=embed_dim[i_layer], depth=depths[i_layer], num_heads=num_heads[i_layer],
                    kernel_size=kernel_size, dilation=dilation,
                    mlp_ratio=self.mlp_ratio, qkv_bias=qkv_bias, qk_scale=qk_scale,
                    drop=drop, attn_drop=attn_drop,
                    drop_path=dpr[sum(depths[:i_layer]):sum(depths[:i_layer + 1])],
                    norm_layer=norm_layer, downsample=downsamples[i_layer],
                    cpe_per_block=cpe_block, cpe_per_satge=cpe_per_satge, merging_way=merging_way)
            else:
                stage = SpsaStage(
                    dim=embed_dim[i_layer], depth=depths[i_layer], num_heads=num_heads[i_layer],
                    mlp_ratio=self.mlp_ratio, qkv_bias=qkv_bias, qk_scale=qk_scale,
                    drop=drop, attn_drop=attn_drop,
                    drop_path=dpr[sum(depths[:i_layer]):sum(depths[:i_layer + 1])],
                    norm_layer=norm_layer, downsample=downsamples[i_layer],
                    cpe_per_block=cpe_block, cpe_per_satge=cpe_per_satge, merging_way=merging_way)
            self.stages.append(stage)

        self.norm = norm_layer(self.num_features)
        self.head = nn.Linear(self.num_features, num_classes) if num_classes > 0 else nn.Identity()

        self.apply(self._init_weights)

    def _init_weights(self, m):
        if isinstance(m, nn.Linear):
            trunc_normal_(m.weight, std=.02)
            if isinstance(m, nn.Linear) and m.bias is not None:
                nn.init.constant_(m.bias, 0)
        elif isinstance(m, nn.LayerNorm):
            nn.init.constant_(m.bias, 0)
            nn.init.constant_(m.weight, 1.0)

    @torch.jit.ignore
    def no_weight_decay(self):
        return {'absolute_pos_embed'}

    def forward_features(self, x):
        x = self.patch_embed(x)

        for i, stage in enumerate(self.stages):
            if i == self.num_layers - 1:
                # Generate cls_token from feature maps at the last stage
                x = self.proj(x)
                cls_tokens = x.mean(dim=[2, 3], keepdim=False).unsqueeze(1)
                x = x.flatten(2).transpose(1, 2)
                x = torch.cat((cls_tokens, x), dim=1)
                x = stage(x)
            else:
                x = stage(x)

        x = self.norm(x)
        return x[:, 0]

    def forward(self, x):
        x = self.forward_features(x)
        x = self.head(x)
        return x


@register_model
def wmtransformer_small(pretrained=True, **kwargs):
    model = WMTransformer(depths=[3, 5, 4], embed_dim=[72, 144, 384], num_heads=[3, 6, 8], **kwargs)
    model.default_cfg = _cfg()
    return model


